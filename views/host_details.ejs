<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Warlock - Host Details</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="<%= assetUrl('/assets/frontend.css') %>">
    <link rel="stylesheet" href="<%= assetUrl('/assets/themes.css') %>">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="<%= assetUrl('/assets/common.js') %>"></script>
</head>
<body data-use-app-background="1">
<%- include('partials/nav.ejs') %>

<div class="main-container wide">
    <main class="content-area">
        <div class="content-header" data-use-app-header="1">
            <div class="content-header-inner">
                <h2>
                    <i class="fas fa-server"></i>
                    <span class="host-name-placeholder">
                        Host Details
                    </span>
                </h2>

                <!--<div class="content-header-buttons">
                    <button class="action-edit" id="btnHostFirewall">
                        <i class="fas fa-shield"></i> Firewall
                    </button>
                    <button class="action-remove" id="btnHostDelete">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>-->
            </div>
        </div>

        <div class="content-subheader">
            <div id="hostDetailOverview" class="host-details-overview">
                <div class="host-cpu">
                    <div class="label">CPU</div>
                    <div id="hostDetailsCpu" class="value">N/A</div>
                    <div class="bargraph-h">
                        <div class="fill"></div>
                    </div>
                </div>
                <div class="host-memory">
                    <div class="label">Memory</div>
                    <div id="hostDetailsMemory" class="value">N/A</div>
                    <div class="bargraph-h">
                        <div class="fill"></div>
                    </div>
                </div>
                <div class="host-network">
                    <div class="label">Network</div>
                    <div id="hostDetailsNetwork" class="value">N/A</div>
                </div>
            </div>
        </div>

        <div class="content-body">
            <nav class="tabs-header">
                <a href="#overview">
                    <i class="fas fa-home"></i> Overview
                </a>
                <a href="#metrics">
                    <i class="fas fa-chart-line"></i> Metrics
                </a>
                <a href="#files">
                    <i class="fas fa-folder"></i> Files
                </a>
                <a href="#firewall">
                    <i class="fas fa-shield"></i> Firewall
                </a>
                <a href="#cron">
                    <i class="fas fa-clock"></i> Cron Jobs
                </a>
                <a href="#settings">
                    <i class="fas fa-cogs"></i> Settings
                </a>
            </nav>

            <div class="tab-target" id="host-details-overview">
                <%- include('partials/host-overview.ejs') %>
            </div>
            <div class="tab-target" id="host-details-metrics">
                <%- include('partials/host-metrics.ejs') %>
            </div>
            <div class="tab-target" id="host-details-files">
                <%- include('partials/host-files.ejs') %>
            </div>
            <div class="tab-target" id="host-details-firewall">
                <%- include('partials/host-firewall.ejs') %>
            </div>
            <div class="tab-target" id="host-details-cron">
                <%- include('partials/host-cron.ejs') %>
            </div>
            <div class="tab-target" id="host-details-settings">
                <%- include('partials/host-settings.ejs') %>
            </div>
        </div>
    </main>
</div>

<%- include('partials/host-firewall-modals.ejs') %>
<%- include('partials/host-cron-modals.ejs') %>
<%- include('partials/service-files-modals.ejs') %>

<%- include('partials/theme-selector.ejs') %>
<script src="<%= assetUrl('/assets/host_details.js') %>"></script>
<script src="<%= assetUrl('/assets/files.js') %>"></script>
<link rel="stylesheet" href="<%= assetUrl('/assets/codemirror/codemirror.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/assets/codemirror/theme/material-darker.css') %>">
<script src="<%= assetUrl('/assets/codemirror/codemirror.js') %>"></script>
</body>
</html>

