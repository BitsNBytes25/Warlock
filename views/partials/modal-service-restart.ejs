<!-- Restart Modal -->
<div id="restartModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-sync-alt"></i> Restart Service</h3>
            <button class="modal-close">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">

            <div class="info-message">
                <p>
                    Choose whether to restart immediately (with a 5 minute warning for active players) or (if supported) with a 1-hour warning.
                </p>
            </div>

            <div>
                <button title="Restart Game" data-action="restart" class="service-control action-restart">
                    <i class="fas fa-sync-alt"></i> <span>Restart Now</span>
                </button>

                <button title="Send 1-hour timer to restart" data-action="delayed-restart" class="service-control action-restart">
                    <i class="fas fa-clock"></i> <span>Delayed Restart</span>
                </button>
            </div>

        </div>
    </div>
</div>

<script>
	const restartModal = document.getElementById('restartModal');

	function openServiceRestartModal(guid, host, service) {
		restartModal.classList.add('show');
		restartModal.querySelectorAll('.service-control').forEach(el => {
			let action = el.dataset.action;
			if (checkHostAppHasOption(guid, host, action)) {
				el.style.display = 'inline-flex';
				el.dataset.guid = guid;
				el.dataset.host = host;
				el.dataset.service = service;
			}
			else {
				el.style.display = 'none';
			}
		});
	}
</script>