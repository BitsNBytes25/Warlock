<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Warlock - Server Hosts</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="<%= assetUrl('/assets/frontend.css') %>">
    <link rel="stylesheet" href="<%= assetUrl('/assets/themes.css') %>">
    <script src="<%= assetUrl('/assets/common.js') %>"></script>
</head>
<body>

<%- include('partials/nav.ejs') %>

<div class="main-container" style="grid-template-columns: 1fr; max-width: 1600px;">
    <main class="content-area">
        <div class="content-header">
            <div class="content-header-inner">
                <h2>
                    <i class="fas fa-server"></i>
                    Fleet Hosts
                </h2>
                <div class="content-header-buttons">
                    <button data-view="card-view" class="action-view view-changer" title="Card View">
                        <i class="fas fa-th-large"></i>
                    </button>
                    <button data-view="table-view" class="action-view view-changer" title="List View">
                        <i class="fas fa-list"></i>
                    </button>
                    <button class="link-control action-create" data-href="/host/add">
                        <i class="fas fa-plus"></i>
                        Add Host
                    </button>
                </div>
                <p>View all servers in your fleet</p>
            </div>
        </div>

        <div class="content-body">
            <!-- Hosts List -->
            <div id="hostsContainer">
                <div id="hosts-table">
                    <div class="header">
                        <div class="hostname">Hostname</div>
                        <div class="ip">IP Address</div>
                        <div class="os">Operating System</div>
                        <div class="cpu">CPU</div>
                        <div class="memory">Memory</div>
                        <div class="disk">Disk</div>
                        <div class="actions">Actions</div>
                    </div>
                    <div class="body">
                        <div class="host host-loading" data-updated="0">
                            <div class="thumbnail"></div>
                            <div class="hostname">Loading...</div>
                            <div class="ip">0.0.0.0</div>
                            <div class="os">Loading OS</div>
                            <div class="cpu">-</div>
                            <div class="memory">- / -</div>
                            <div class="disk">-</div>
                            <div class="actions"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('partials/theme-selector.ejs') %>

<script src="<%= assetUrl('/assets/hosts.js') %>"></script>
</body>
</html>

