<!-- Automatic Restart Cron Configuration Modal -->
<div id="autoRestartModal" class="modal">
	<div class="modal-overlay"></div>
	<div class="modal-content">
		<div class="modal-header">
			<h3><i class="fas fa-power-off"></i> Automatic Restart Configuration</h3>
			<button class="modal-close">
				<i class="fas fa-times"></i>
			</button>
		</div>
		<div class="modal-body">
			<div class="form-group">
				<label for="autoRestartSchedule">Schedule</label>
				<select id="autoRestartSchedule" name="schedule">
					<option value="disabled">Disabled</option>
					<option value="hourly">Hourly</option>
					<option value="daily">Daily</option>
					<option value="weekly">Weekly</option>
				</select>
			</div>

			<div class="form-group" id="autoRestartWeeklyDayRow">
				<label for="autoRestartWeeklyDay">Weekly Day</label>
				<select id="autoRestartWeeklyDay" name="weekly_day">
					<option value="mon">Monday</option>
					<option value="tue">Tuesday</option>
					<option value="wed">Wednesday</option>
					<option value="thu">Thursday</option>
					<option value="fri">Friday</option>
					<option value="sat">Saturday</option>
					<option value="sun">Sunday</option>
				</select>
			</div>

			<div class="form-group">
				<label for="autoRestartTime">Time</label>
				<input type="time" id="autoRestartTime" name="time" value="02:00">
			</div>
		</div>
		<div class="modal-footer">
			<button class="action-save" id="saveAutoRestartBtn">
				<i class="fas fa-save"></i>
				Save Configuration
			</button>
			<button class="action-cancel modal-close">
				<i class="fas fa-times"></i>
				Cancel
			</button>
		</div>
	</div>
</div>

<script>

	let openAutoRestartModalCallback;

	function openAutoRestartModal(host, application, service, callback) {
		const modal = document.getElementById('autoRestartModal'),
			hostData = getHostInstallData(application, host);

		if (!hostData) {
			showToast('error', 'Host data not found for this application.');
			return;
		}

		const appVersion = hostData.version;

		let identifier;
		if (service && appVersion >= 2) {
			identifier = `${application}_${service}_restart`;
		}
		else {
			identifier = `${application}_restart`;
		}

		modal.dataset.host = host;
		modal.dataset.guid = application;
		modal.dataset.service = service;
		openModal(modal);
		openAutoRestartModalCallback = callback;

		loadCronJob(host, identifier, modal).catch(e => {
			console.error('Error loading cron job:', e);
			showToast('error', 'Error loading automatic updates configuration.');
		});
	}

	async function saveAutomaticRestarts() {
		const modal = document.getElementById('autoRestartModal'),
			application = modal.dataset.guid,
			host = modal.dataset.host,
			service = modal.dataset.service,
			hostData = getHostInstallData(application, host),
			appVersion = hostData.version,
			appDir = hostData.path;

		let command, identifier;

		if (service && appVersion >= 2) {
			identifier = `${application}_${service}_restart`;
		}
		else {
			identifier = `${application}_restart`;
		}

		const schedule = parseCronSchedule(modal);
		closeModal(modal);

		if (schedule === 'DISABLED') {
			// Delete existing identifier
			fetch(`/api/cron/${host}`, {
				method: 'DELETE',
				headers: {'Content-Type': 'application/json'},
				body: JSON.stringify({identifier})
			})
				.then(r => r.json())
				.then(response => {
					if (response.success) {
						showToast('success', 'Automatic restarts disabled.');
						if (openAutoRestartModalCallback) {
							openAutoRestartModalCallback();
							openAutoRestartModalCallback = null;
						}
					}
					else {
						showToast('error', `Failed to disable automatic restarts: ${response.error}`);
					}
				})
				.catch(() => showToast('error', 'Error disabling automatic restarts'));
			return;
		}

		// if this service supports delayed-restart, use that instead
		if (hostData.options.includes('delayed-restart')) {
			command = 'delayed-restart';
		}
		else {
			command = 'restart';
		}
		// Build command for delayed updates
		if (service && appVersion >= 2) {
			command = `${appDir}/manage.py ${command} --service ${service}`;
		}
		else if (appVersion >= 2) {
			command = `${appDir}/manage.py ${command}`;
		}
		else {
			command = `${appDir}/manage.py --${command}`;
		}

		fetch(`/api/cron/${host}`, {
			method: 'POST',
			headers: {'Content-Type': 'application/json'},
			body: JSON.stringify({schedule, command, identifier})
		})
			.then(r => r.json())
			.then(response => {
				if (response.success) {
					showToast('success', 'Automatic restarts scheduled.');
					if (openAutoRestartModalCallback) {
						openAutoRestartModalCallback();
						openAutoRestartModalCallback = null;
					}
				} else {
					showToast('error', `Failed to save schedule: ${response.error}`);
				}
			})
			.catch(() => showToast('error', 'Error saving schedule'));
	}

	window.addEventListener('DOMContentLoaded', () => {
		document.getElementById('saveAutoRestartBtn').addEventListener('click', saveAutomaticRestarts);
	});
</script>