<!-- Automatic Update Check Cron Configuration Modal -->
<div id="autoUpdateModal" class="modal">
	<div class="modal-overlay"></div>
	<div class="modal-content">
		<div class="modal-header">
			<h3><i class="fas fa-clock"></i> Automatic Update Configuration</h3>
			<button class="modal-close">
				<i class="fas fa-times"></i>
			</button>
		</div>
		<div class="modal-body">
			<div class="form-group">
				<label for="autoUpdateSchedule">Schedule</label>
				<select id="autoUpdateSchedule" name="schedule">
					<option value="disabled">Disabled</option>
					<option value="hourly">Hourly</option>
					<option value="daily">Daily</option>
					<option value="weekly">Weekly</option>
				</select>
			</div>

			<div class="form-group" id="autoUpdateWeeklyDayRow">
				<label for="autoUpdateWeeklyDay">Weekly Day</label>
				<select id="autoUpdateWeeklyDay" name="weekly_day">
					<option value="mon">Monday</option>
					<option value="tue">Tuesday</option>
					<option value="wed">Wednesday</option>
					<option value="thu">Thursday</option>
					<option value="fri">Friday</option>
					<option value="sat">Saturday</option>
					<option value="sun">Sunday</option>
				</select>
			</div>

			<div class="form-group">
				<label for="autoUpdateTime">Time</label>
				<input type="time" id="autoUpdateTime" name="time" value="02:00">
			</div>

			<div class="form-group">
				<label for="delayedUpdate">Update if Players Online</label>
				<input type="checkbox" id="delayedUpdate" name="delayed_update">
				<p class="form-help-text">
					If enabled, updates will run even if players are online, with a 1-hour warning.
					Otherwise, restart/updates will be skipped if players are detected.
				</p>
			</div>
		</div>
		<div class="modal-footer">
			<button class="action-save" id="saveAutoUpdateBtn">
				<i class="fas fa-save"></i>
				Save Configuration
			</button>
			<button class="action-cancel modal-close">
				<i class="fas fa-times"></i>
				Cancel
			</button>
		</div>
	</div>
</div>

<script>

	let openAutoUpdateModalCallback;

	function openAutoUpdateModal(host, application, service, callback) {
		const modal = document.getElementById('autoUpdateModal'),
			hostData = getHostInstallData(application, host);

		if (!hostData) {
			showToast('error', 'Host data not found for this application.');
			return;
		}

		const appVersion = hostData.version;

		let identifier;
		if (service && appVersion >= 2) {
			identifier = `${application}_${service}_update`;
		}
		else {
			identifier = `${application}_update`;
		}

		modal.dataset.host = host;
		modal.dataset.guid = application;
		modal.dataset.service = service;
		openModal(modal);
		openAutoUpdateModalCallback = callback;

		loadCronJob(host, identifier, modal).then(job => {
			let delayedUpdate = document.getElementById('delayedUpdate');
			if (!hostData.options.includes('delayed-update')) {
				delayedUpdate.closest('.form-group').querySelector('p').textContent = 'Note: this game does not support delayed updates.';
				delayedUpdate.disabled = true;
				delayedUpdate.checked = false;
			}
			else if (job && job.command) {
				delayedUpdate.checked = job.command.includes('delayed-update') && !job.command.startsWith('!');
			}
		}).catch(e => {
			console.error('Error loading cron job:', e);
			showToast('error', 'Error loading automatic updates configuration.');
		});
	}

	async function saveAutomaticUpdates() {
		const modal = document.getElementById('autoUpdateModal'),
			application = modal.dataset.guid,
			host = modal.dataset.host,
			service = modal.dataset.service,
			hostData = getHostInstallData(application, host),
			appVersion = hostData.version,
			appDir = hostData.path,
			delayedUpdate = document.getElementById('delayedUpdate');

		let command, identifier;

		if (service && appVersion >= 2) {
			identifier = `${application}_${service}_update`;
		}
		else {
			identifier = `${application}_update`;
		}

		const schedule = parseCronSchedule(modal);
		closeModal(modal);

		if (schedule === 'DISABLED') {
			// Delete existing identifier
			fetch(`/api/cron/${host}`, {
				method: 'DELETE',
				headers: {'Content-Type': 'application/json'},
				body: JSON.stringify({identifier})
			})
				.then(r => r.json())
				.then(response => {
					if (response.success) {
						showToast('success', 'Automatic updates disabled.');
						if (openAutoUpdateModalCallback) {
							openAutoUpdateModalCallback();
							openAutoUpdateModalCallback = null;
						}
					}
					else {
						showToast('error', `Failed to disable automatic updates: ${response.error}`);
					}
				})
				.catch(() => showToast('error', 'Error disabling automatic updates'));
			return;
		}

		if (hostData.options.includes('delayed-update') && delayedUpdate.checked) {
			// Build command for delayed updates
			if (service && appVersion >= 2) {
				command = `${appDir}/manage.py check-update --service ${service} &&` +
					`${appDir}/manage.py delayed-update --service ${service}`;
			}
			else {
				command = `${appDir}/manage.py --check-update && ${appDir}/manage.py --delayed-update`;
			}
		}
		else {
			if (service && appVersion >= 2) {
				command = `! ${appDir}/manage.py has-players --service ${service} &&` +
					` ${appDir}/manage.py check-update --service ${service} &&` +
					` ${appDir}/manage.py update --service ${service}`;
			}
			else {
				command = `! ${appDir}/manage.py --has-players && ${appDir}/manage.py --check-update && ${appDir}/manage.py --update`;
			}
		}

		fetch(`/api/cron/${host}`, {
			method: 'POST',
			headers: {'Content-Type': 'application/json'},
			body: JSON.stringify({schedule, command, identifier})
		})
			.then(r => r.json())
			.then(response => {
				if (response.success) {
					showToast('success', 'Automatic updates scheduled.');
					if (openAutoUpdateModalCallback) {
						openAutoUpdateModalCallback();
						openAutoUpdateModalCallback = null;
					}
				} else {
					showToast('error', `Failed to save schedule: ${response.error}`);
				}
			})
			.catch(() => showToast('error', 'Error saving schedule'));
	}

	window.addEventListener('DOMContentLoaded', () => {
		document.getElementById('autoUpdateSchedule').addEventListener('change', e => {
			let delayedUpdate = document.getElementById('delayedUpdate').closest('.form-group');

			if (e.target.value === 'disabled') {
				delayedUpdate.style.display = 'none';
			}
			else {
				delayedUpdate.style.display = 'flex';
			}
		});
		document.getElementById('saveAutoUpdateBtn').addEventListener('click', saveAutomaticUpdates);
	})
</script>
