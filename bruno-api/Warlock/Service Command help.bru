meta {
  name: Service Command help
  type: http
  seq: 15
}

post {
  url: {{host}}/api/service/cmd/:guid/:host/:service
  body: json
  auth: inherit
}

params:path {
  service: {{lookup_service}}
  host: {{lookup_host}}
  guid: {{lookup_app}}
}

body:json {
  {"command": "help"}
}

body:text {
  help
}

settings {
  encodeUrl: true
  timeout: 0
}
