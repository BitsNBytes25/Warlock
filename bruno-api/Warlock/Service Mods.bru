meta {
  name: Service Mods
  type: http
  seq: 35
}

get {
  url: {{host}}/api/service/mods/:guid/:host/:service
  body: json
  auth: inherit
}

params:path {
  guid: {{lookup_app}}
  service: {{lookup_service}}
  host: {{lookup_host}}
}

body:json {
  {"key1": "value1"}
}

settings {
  encodeUrl: true
  timeout: 0
}
