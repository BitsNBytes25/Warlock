meta {
  name: Service Start
  type: http
  seq: 8
}

post {
  url: {{host}}/api/service/control/:guid/:host/:service
  body: json
  auth: inherit
}

params:path {
  service: {{lookup_service}}
  host: {{lookup_host}}
  guid: {{lookup_app}}
}

body:json {
  {"action": "start"}
}

settings {
  encodeUrl: true
  timeout: 0
}
