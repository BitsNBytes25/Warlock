meta {
  name: Application Update (Service)
  type: http
  seq: 20
}

get {
  url: {{host}}/api/application/update/:guid/:host/:service
  body: none
  auth: inherit
}

params:path {
  service: {{lookup_service}}
  host: {{lookup_host}}
  guid: {{lookup_app}}
}

settings {
  encodeUrl: true
  timeout: 0
}
