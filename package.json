{
  "name": "warlock-express-app",
  "version": "1.2.1",
  "description": "Express app serving HTML pages",
  "main": "app.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "start:profile": "WARLOCK_PROFILE=1 node app.js",
    "dev": "NODE_ENV=development nodemon app.js",
    "dev:quick": "NODE_ENV=development SKIP_AUTOMATIONS=1 nodemon app.js",
    "dev:profile": "NODE_ENV=development WARLOCK_PROFILE=1 nodemon app.js",
    "docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "cli": "node cli.js",
    "prune-duplicates": "node tasks/prune_duplicates.js",
    "test": "node --test --experimental-test-module-mocks tests/*"
  },
  "keywords": [
    "express",
    "html",
    "server"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.8",
    "bcrypt": "^6.0.0",
    "body-parser": "2.2.2",
    "connect-sqlite3": "^0.9.16",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "js-yaml": "^4.1.1",
    "node-2fa": "^2.0.3",
    "node-cache": "^5.1.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "tar": "^7.5.11",
    "dottie": ">=2.0.7",
    "node-gyp": ">12.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
